{
  "name": "gemma-endpoint",
  "version": "1.0.0",
  "description": "Local proxy server: OpenAI-compatible API → Google AI Studio (Gemma 3 27B)",
  "main": "dist/server.js",
  "scripts": {
    "build:server": "tsc",
    "build:client": "cd client && npx vite build",
    "build": "npm run build:server && npm run build:client",
    "dev:server": "tsc --watch",
    "dev:client": "cd client && npx vite --port 5173",
    "start": "node dist/server.js"
  },
  "keywords": [
    "gemma",
    "proxy",
    "openai",
    "google-ai"
  ],
  "license": "MIT",
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "cors": "^2.8.5",
    "express": "^4.21.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.19.15",
    "typescript": "^5.7.0"
  }
}
